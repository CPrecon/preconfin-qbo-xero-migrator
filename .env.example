# Shared
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MARKETING_URL=https://preconfin.com
NEXT_PUBLIC_MARKETING_TOOL_URL=https://preconfin.com/tools/quickbooks-to-xero
NEXT_PUBLIC_PRIVACY_URL=http://localhost:3000/privacy
NEXT_PUBLIC_TERMS_URL=http://localhost:3000/terms
NEXT_PUBLIC_SUPPORT_URL=https://preconfin.com/contact
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
LIVE_CERTIFICATION_MODE=false

# Intuit QuickBooks Online
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=http://localhost:4000/api/oauth/qbo/callback
INTUIT_ENVIRONMENT=sandbox
QBO_MINOR_VERSION=75
QBO_REPORT_BASIS=Accrual

# Security
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
OAUTH_STATE_SIGNING_SECRET=replace-with-random-32-byte-secret

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=migration-artifacts
ARTIFACT_RETENTION_DAYS=14
SIGNED_URL_TTL_SECONDS=3600

# API
API_PORT=4000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# Xero certification-only settings
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
