{
  "name": "@preconfin/qbo-xero-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "verify:env:live": "tsx src/verify-live-env.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@preconfin/canonical-model": "0.1.0",
    "@preconfin/migration-engine": "0.1.0",
    "@preconfin/pdf-report": "0.1.0",
    "@preconfin/validation-engine": "0.1.0",
    "@preconfin/xero-export": "0.1.0",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.86.0"
  }
}
