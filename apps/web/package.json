{
  "name": "@preconfin/qbo-xero-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --config ../../eslint.config.mjs",
    "test": "vitest run",
    "pages:build": "opennextjs-cloudflare build",
    "deploy": "opennextjs-cloudflare deploy",
    "start": "next start",
    "worker:dev": "opennextjs-cloudflare preview",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production --keep-vars",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "pages:build:staging": "NEXT_PUBLIC_APP_URL=https://migrate-staging.preconfin.com NEXT_PUBLIC_API_URL=https://migrate-staging.preconfin.com NEXT_PUBLIC_MARKETING_URL=https://preconfin.com NEXT_PUBLIC_MARKETING_TOOL_URL=https://preconfin.com/tools/quickbooks-to-xero NEXT_PUBLIC_PRIVACY_URL=https://migrate-staging.preconfin.com/privacy NEXT_PUBLIC_TERMS_URL=https://migrate-staging.preconfin.com/terms NEXT_PUBLIC_SUPPORT_URL=https://preconfin.com/contact NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com opennextjs-cloudflare build",
    "pages:build:production": "NEXT_PUBLIC_APP_URL=https://migrate.preconfin.com NEXT_PUBLIC_API_URL=https://api-migrate.preconfin.com NEXT_PUBLIC_MARKETING_URL=https://preconfin.com NEXT_PUBLIC_MARKETING_TOOL_URL=https://preconfin.com/tools/quickbooks-to-xero NEXT_PUBLIC_PRIVACY_URL=https://migrate.preconfin.com/privacy NEXT_PUBLIC_TERMS_URL=https://migrate.preconfin.com/terms NEXT_PUBLIC_SUPPORT_URL=https://preconfin.com/contact NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com opennextjs-cloudflare build"
  },
  "dependencies": {
    "@preconfin/shared-ui": "0.1.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "posthog-js": "^1.203.1",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.86.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "rclone.js": "^0.6.6"
  }
}
