{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "preconfin-qbo-xero-migrator-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "persist": true,
      "invocation_logs": true,
    },
  },
  "vars": {
    "APP_ENV": "temporary",
    "NEXT_PUBLIC_APP_URL": "https://migrate-staging.preconfin.com",
    "NEXT_PUBLIC_API_URL": "https://migrate-staging.preconfin.com",
    "NEXT_PUBLIC_MARKETING_URL": "https://preconfin.com",
    "NEXT_PUBLIC_MARKETING_TOOL_URL": "https://preconfin.com/tools/quickbooks-to-xero",
    "NEXT_PUBLIC_PRIVACY_URL": "https://migrate-staging.preconfin.com/privacy",
    "NEXT_PUBLIC_TERMS_URL": "https://migrate-staging.preconfin.com/terms",
    "NEXT_PUBLIC_SUPPORT_URL": "https://preconfin.com/contact",
    "NEXT_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
  },
  "env": {
    "staging": {
      "name": "preconfin-qbo-xero-migrator-web-staging",
      "workers_dev": true,
      "routes": [
        {
          "pattern": "migrate-staging.preconfin.com/*",
          "zone_name": "preconfin.com",
        },
      ],
      "vars": {
        "APP_ENV": "staging",
        "NEXT_PUBLIC_APP_URL": "https://migrate-staging.preconfin.com",
        "NEXT_PUBLIC_API_URL": "https://migrate-staging.preconfin.com",
        "NEXT_PUBLIC_MARKETING_URL": "https://preconfin.com",
        "NEXT_PUBLIC_MARKETING_TOOL_URL": "https://preconfin.com/tools/quickbooks-to-xero",
        "NEXT_PUBLIC_PRIVACY_URL": "https://migrate-staging.preconfin.com/privacy",
        "NEXT_PUBLIC_TERMS_URL": "https://migrate-staging.preconfin.com/terms",
        "NEXT_PUBLIC_SUPPORT_URL": "https://preconfin.com/contact",
        "NEXT_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
      },
    },
    "production": {
      "name": "preconfin-qbo-xero-migrator-web",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "migrate.preconfin.com",
          "custom_domain": true,
        },
      ],
      "vars": {
        "APP_ENV": "production",
        "NEXT_PUBLIC_APP_URL": "https://migrate.preconfin.com",
        "NEXT_PUBLIC_API_URL": "https://api-migrate.preconfin.com",
        "NEXT_PUBLIC_MARKETING_URL": "https://preconfin.com",
        "NEXT_PUBLIC_MARKETING_TOOL_URL": "https://preconfin.com/tools/quickbooks-to-xero",
        "NEXT_PUBLIC_PRIVACY_URL": "https://migrate.preconfin.com/privacy",
        "NEXT_PUBLIC_TERMS_URL": "https://migrate.preconfin.com/terms",
        "NEXT_PUBLIC_SUPPORT_URL": "https://preconfin.com/contact",
        "NEXT_PUBLIC_POSTHOG_HOST": "https://us.i.posthog.com",
      },
    },
  },
}
