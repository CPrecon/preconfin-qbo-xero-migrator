{
  "name": "@preconfin/financial-assessment-engine",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./schema/financial-assessment-v1.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "fixtures:update": "tsx scripts/generate-golden.ts",
    "baseline:compare": "tsx scripts/compare-baseline.ts",
    "test:contract:python": "python3 scripts/validate-contract.py"
  },
  "dependencies": {
    "@preconfin/canonical-model": "0.1.0",
    "@preconfin/migration-engine": "0.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
